# EC (P-256) configuration for the tonic mTLS demo.
# Copy to .env (or pass via ENV_FILE=.env.ec) before running scripts.
#
#   cp .env.ec.example .env.ec
#   ENV_FILE=.env.ec ./generate-certs.sh
#   ENV_FILE=.env.ec ./start-server.sh
#   ENV_FILE=.env.ec ./run-client.sh
#
# NOTE: The HSM_KEY_NAME below must point to an EC-HSM key (e.g., curve P-256)
# in your Managed HSM. Provision via:
#   az keyvault key create --hsm-name <HSM_NAME> --name ecckey \
#     --kty EC-HSM --curve P-256 --ops sign verify

# === Azure Managed HSM ===
HSM_NAME=ManagedHSMOpenSSLEngine
HSM_KEY_NAME=ecckey
AZURE_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47

# === Cert identities (used by generate-certs.sh) ===
SERVER_CN=localhost
CLIENT_CN=tonic-grpc-client
CERT_ORG=Microsoft
CERT_OU="Azure HSM gRPC Tonic Demo (EC)"
CERT_COUNTRY=US
CERT_STATE=Washington
CERT_CITY=Redmond
CERT_DAYS=365

# === gRPC transport ===
GRPC_BIND_ADDR=0.0.0.0:50443
GRPC_SERVER_ADDR=https://localhost:50443
GRPC_SERVER_NAME=localhost

# === Logging ===
RUST_LOG=info
AKV_LOG_LEVEL=info
