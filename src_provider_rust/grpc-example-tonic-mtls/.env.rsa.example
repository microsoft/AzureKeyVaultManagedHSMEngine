# RSA configuration for the tonic mTLS demo.
# Copy to .env (or pass via ENV_FILE=.env.rsa) before running scripts.
#
#   cp .env.rsa.example .env.rsa
#   ENV_FILE=.env.rsa ./generate-certs.sh
#   ENV_FILE=.env.rsa ./start-server.sh
#   ENV_FILE=.env.rsa ./run-client.sh

# === Azure Managed HSM ===
HSM_NAME=ManagedHSMOpenSSLEngine
HSM_KEY_NAME=myrsakey
AZURE_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47

# === Cert identities (used by generate-certs.sh) ===
SERVER_CN=localhost
CLIENT_CN=tonic-grpc-client
CERT_ORG=Microsoft
CERT_OU="Azure HSM gRPC Tonic Demo (RSA)"
CERT_COUNTRY=US
CERT_STATE=Washington
CERT_CITY=Redmond
CERT_DAYS=365

# === gRPC transport ===
GRPC_BIND_ADDR=0.0.0.0:50443
GRPC_SERVER_ADDR=https://localhost:50443
GRPC_SERVER_NAME=localhost

# === Logging ===
RUST_LOG=info
AKV_LOG_LEVEL=info
